{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/chat-server", "sidecar": true }]
    }
  ]
}
